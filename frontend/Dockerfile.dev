# Development Dockerfile for React/Vite
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

# We don't need to COPY . . here because the docker-compose volume handles it!

EXPOSE 3000

# Run the development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]